<Window x:Class="LocalMusicHub.TagEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit tags"
        Height="520" Width="520"
        MinHeight="460" MinWidth="440"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Edit tags" Style="{DynamicResource HubSectionTitle}" FontSize="18"/>
            <TextBlock x:Name="FilePathText" Style="{DynamicResource HubHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{DynamicResource HubCardBorder}" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Title" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,10"/>
                    <TextBox x:Name="TitleBox" Grid.Column="1" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1" Text="Artist" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,10"/>
                    <TextBox x:Name="ArtistBox" Grid.Row="1" Grid.Column="1" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2" Text="Album artist" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,10"/>
                    <TextBox x:Name="AlbumArtistBox" Grid.Row="2" Grid.Column="1" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="3" Text="Album" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,10"/>
                    <TextBox x:Name="AlbumBox" Grid.Row="3" Grid.Column="1" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="4" Text="Track #" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,10"/>
                    <TextBox x:Name="TrackNumberBox" Grid.Row="4" Grid.Column="1" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="5" Text="Year" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,10"/>
                    <TextBox x:Name="YearBox" Grid.Row="5" Grid.Column="1" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="6" Text="Genre" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,10"/>
                    <TextBox x:Name="GenreBox" Grid.Row="6" Grid.Column="1" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="7" Text="Rating" Style="{DynamicResource HubSettingLabel}"/>
                    <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                        <Button Content="☆" Tag="0" Style="{DynamicResource HubToolbarButton}" Click="Rating_OnClick" ToolTip="Clear rating"/>
                        <Button Content="★" Tag="1" Style="{DynamicResource HubToolbarButton}" Click="Rating_OnClick"/>
                        <Button Content="★★" Tag="2" Style="{DynamicResource HubToolbarButton}" Click="Rating_OnClick"/>
                        <Button Content="★★★" Tag="3" Style="{DynamicResource HubToolbarButton}" Click="Rating_OnClick"/>
                        <Button Content="★★★★" Tag="4" Style="{DynamicResource HubToolbarButton}" Click="Rating_OnClick"/>
                        <Button Content="★★★★★" Tag="5" Style="{DynamicResource HubToolbarButton}" Click="Rating_OnClick"/>
                        <TextBlock x:Name="RatingText" Style="{DynamicResource HubHintText}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Style="{DynamicResource HubToolbarButton}" IsCancel="True" Padding="14,8"/>
            <Button Content="Save" Style="{DynamicResource HubPrimaryButton}" IsDefault="True" Padding="16,8" Click="Save_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
