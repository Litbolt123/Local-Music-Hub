<Window x:Class="LocalMusicHub.AddToPlaylistPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LocalMusicHub"
        Title="Add to playlist"
        Height="520" Width="420"
        MinHeight="400" MinWidth="360"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <local:CoverArtToImageConverter x:Key="CoverArtConverter"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12">
            <TextBlock Text="Add to playlist" Style="{DynamicResource HubSectionTitle}" FontSize="18"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="SubtitleText" DockPanel.Dock="Right" Style="{DynamicResource HubHintText}"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
        </DockPanel>

        <TextBox x:Name="SearchBox" Grid.Row="1" Style="{DynamicResource HubTextBox}" Height="34"
                 VerticalContentAlignment="Center" Margin="0,0,0,10"
                 TextChanged="SearchBox_OnTextChanged"
                 ToolTip="Search playlists"/>

        <TextBlock Grid.Row="2" Style="{DynamicResource HubHintText}" Margin="0,0,0,8"
                   Text="Choose a playlist, or create a new one."/>

        <ListBox x:Name="PlaylistList" Grid.Row="3"
                 BorderThickness="0" Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="PlaylistList_OnMouseDoubleClick"
                 KeyDown="PlaylistList_OnKeyDown">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,8" Margin="0,0,0,4" CornerRadius="8"
                            Background="{DynamicResource HubMetricBgBrush}">
                        <DockPanel>
                            <Border DockPanel.Dock="Left" Width="44" Height="44" CornerRadius="6" Margin="0,0,12,0"
                                    Background="{DynamicResource HubSurfaceRaisedBrush}" ClipToBounds="True">
                                <Image Source="{Binding CoverArt, Converter={StaticResource CoverArtConverter}, ConverterParameter=44}"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" Style="{DynamicResource HubBodyText}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Style="{DynamicResource HubHintText}" FontSize="12"
                                           Text="{Binding TrackCount, StringFormat={}{0} songs}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="New playlist…" Style="{DynamicResource HubToolbarButton}" Margin="0,0,8,0"
                    Padding="12,7" Click="NewPlaylist_OnClick"/>
            <Button Content="Cancel" Style="{DynamicResource HubToolbarButton}" IsCancel="True" Padding="14,7" Margin="0,0,8,0"/>
            <Button Content="Add" Style="{DynamicResource HubPrimaryButton}" IsDefault="True" Padding="16,7"
                    Click="Add_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
