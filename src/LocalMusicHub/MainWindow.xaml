<Window x:Class="LocalMusicHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LocalMusicHub"
        xmlns:models="clr-namespace:LocalMusicHub.Models"
        Title="Local Music Hub"
        Height="900" Width="1280"
        MinHeight="640" MinWidth="980"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_OnLoaded"
        ContentRendered="MainWindow_OnContentRendered"
        Closing="MainWindow_OnClosing"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown">
    <Window.Resources>
        <local:CoverArtToImageConverter x:Key="CoverArtConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <Geometry x:Key="IconPlayGeo">M8,5 L19,12 L8,19 Z</Geometry>
        <Geometry x:Key="IconPauseGeo">M6,5 H10 V19 H6 Z M14,5 H18 V19 H14 Z</Geometry>

        <DataTemplate x:Key="TrackListItemTemplate">
            <Grid HorizontalAlignment="Stretch" MinWidth="200">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="64"/>
                </Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding DisplayArtist}" Style="{DynamicResource HubHintText}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding RatingLabel}" VerticalAlignment="Center"
                           HorizontalAlignment="Center" Style="{DynamicResource HubHintText}"/>
                <TextBlock Grid.Column="2" Text="{Binding DurationLabel}" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Style="{DynamicResource HubHintText}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AlbumTrackListItemTemplate">
            <Grid HorizontalAlignment="Stretch" MinWidth="280" Margin="0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="72"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding TrackNumber}" VerticalAlignment="Center" HorizontalAlignment="Center"
                           Style="{DynamicResource HubHintText}" FontSize="13"/>
                <StackPanel Grid.Column="1" Margin="8,0,24,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold" FontSize="14"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding DisplayArtist}" Style="{DynamicResource HubHintText}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding DurationLabel}" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Style="{DynamicResource HubHintText}" FontSize="13"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AlbumListItemTemplate">
            <StackPanel>
                <TextBlock Text="{Binding DisplayLabel}" FontWeight="SemiBold"
                           Foreground="{DynamicResource HubTextPrimaryBrush}"/>
                <TextBlock Text="{Binding TrackCount, StringFormat={}{0} tracks}" Style="{DynamicResource HubHintText}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ArtistListItemTemplate">
            <StackPanel>
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                           Foreground="{DynamicResource HubTextPrimaryBrush}"/>
                <TextBlock Text="{Binding TrackCount, StringFormat={}{0} tracks}" Style="{DynamicResource HubHintText}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="GenreListItemTemplate">
            <StackPanel>
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                           Foreground="{DynamicResource HubTextPrimaryBrush}"/>
                <TextBlock Text="{Binding Subtitle}" Style="{DynamicResource HubHintText}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="AlbumGridItemTemplate">
            <Border Width="160" Margin="10,8" Cursor="Hand" Background="Transparent"
                    BorderThickness="2" CornerRadius="12" Padding="4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource HubAccentBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border Width="152" Height="152" CornerRadius="10"
                            Background="{DynamicResource HubMetricBgBrush}" ClipToBounds="True">
                        <!-- Transparent background so the whole tile receives mouse-over -->
                        <Grid x:Name="AlbumCoverHost" Background="Transparent">
                            <TextBlock Text="♪" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource HubTextMutedBrush}" IsHitTestVisible="False"/>
                            <Image Source="{Binding CoverThumbnail}"
                                   Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                            <Border Background="#66000000" IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <!-- Hover play: Pause only on the album that is actively playing -->
                            <Button Tag="AlbumPlay" Width="40" Height="40" Margin="0,0,8,8"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Cursor="Hand" Click="AlbumCardPlay_OnClick"
                                    ToolTip="Play album">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="PlayChrome" Background="{DynamicResource HubAccentBrush}"
                                                CornerRadius="20" Width="40" Height="40">
                                            <Grid>
                                                <Path x:Name="PlayGlyph" Data="{StaticResource IconPlayGeo}" Width="14" Height="14"
                                                      Stretch="Uniform" Fill="{DynamicResource HubPrimaryForegroundBrush}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                                <Path x:Name="PauseGlyph" Data="{StaticResource IconPauseGeo}" Width="14" Height="14"
                                                      Stretch="Uniform" Fill="{DynamicResource HubPrimaryForegroundBrush}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="PlayChrome" Property="Background" Value="{DynamicResource HubAccentHoverBrush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding ShowPause}" Value="True">
                                                <Setter TargetName="PlayGlyph" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="PauseGlyph" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Opacity" Value="0"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                        <Setter Property="ToolTip" Value="Play album"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Setter Property="IsHitTestVisible" Value="True"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ShowPause}" Value="True">
                                                <Setter Property="ToolTip" Value="Pause album"/>
                                                <Setter Property="Opacity" Value="1"/>
                                                <Setter Property="IsHitTestVisible" Value="True"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding Album}" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource HubTextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" Margin="0,8,0,2"/>
                    <TextBlock Text="{Binding AlbumArtist}" Style="{DynamicResource HubHintText}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding TrackCount, StringFormat={}{0} tracks}" Style="{DynamicResource HubHintText}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PlaylistNavItemTemplate">
            <StackPanel Orientation="Horizontal">
                <Border Width="32" Height="32" CornerRadius="4" Margin="0,0,10,0"
                        Background="{DynamicResource HubSurfaceRaisedBrush}">
                    <Image Source="{Binding CoverArt, Converter={StaticResource CoverArtConverter}, ConverterParameter=32}"
                           Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="{Binding NavLabel}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TrackCount, StringFormat={} ({0})}" Style="{DynamicResource HubHintText}"
                           Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <ContextMenu x:Key="LibraryContextMenu" Opened="LibraryContextMenu_OnOpened">
            <MenuItem Header="Play" Click="ContextPlay_OnClick"/>
            <MenuItem Header="Play next" Click="ContextPlayNext_OnClick"/>
            <MenuItem Header="Add to queue" Click="ContextAddToQueue_OnClick"/>
            <MenuItem Header="Add to playlist…" Click="ContextAddToPlaylist_OnClick"/>
            <MenuItem Header="Remove from playlist" Click="ContextRemoveFromPlaylist_OnClick"/>
            <MenuItem Header="Edit album…" Click="ContextEditAlbum_OnClick"/>
            <MenuItem Header="Download lyrics for album…" Click="ContextDownloadAlbumLyrics_OnClick"/>
            <Separator/>
            <MenuItem Header="Mark inbox done" Click="ContextMarkInboxDone_OnClick"/>
            <MenuItem Header="Show in Explorer" Click="ContextShowInExplorer_OnClick"/>
            <MenuItem Header="Edit tags…" Click="ContextEditTags_OnClick"/>
            <MenuItem Header="MusicBrainz lookup…" Click="ContextMusicBrainz_OnClick"/>
            <MenuItem Header="Identify with AcoustID…" Click="ContextAcoustId_OnClick"/>
            <MenuItem Header="Rate">
                <MenuItem Header="Clear" Tag="0" Click="ContextRate_OnClick"/>
                <MenuItem Header="★" Tag="1" Click="ContextRate_OnClick"/>
                <MenuItem Header="★★" Tag="2" Click="ContextRate_OnClick"/>
                <MenuItem Header="★★★" Tag="3" Click="ContextRate_OnClick"/>
                <MenuItem Header="★★★★" Tag="4" Click="ContextRate_OnClick"/>
                <MenuItem Header="★★★★★" Tag="5" Click="ContextRate_OnClick"/>
            </MenuItem>
        </ContextMenu>

        <!-- Simple line-style transport icons (24×24) -->
        <Style x:Key="HubTransportIcon" TargetType="Path">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Fill" Value="{DynamicResource HubTextPrimaryBrush}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Geometry x:Key="IconPrevGeo">M5,5 V19 H7.2 V12.8 L17.8,19.5 V4.5 L7.2,11.2 V5 Z</Geometry>
        <Geometry x:Key="IconNextGeo">M6.2,4.5 L16.8,11.2 V5 H19 V19 H16.8 V12.8 L6.2,19.5 Z</Geometry>
        <Geometry x:Key="IconShuffleGeo">M10.59,9.17 L5.41,4 4,5.41 9.17,10.59 10.59,9.17 Z M14.5,4 L16.54,6.04 4,18.59 5.41,20 17.96,7.46 20,9.5 V4 H14.5 Z M14.83,13.41 L13.42,14.82 16.55,17.95 14.5,20 H20 V14.5 L17.96,16.54 14.83,13.41 Z</Geometry>
        <Geometry x:Key="IconRepeatGeo">M7,7 H17 V10.2 L21,6 17,1.8 V5 H5 V11 H7 V7 Z M17,17 H7 V13.8 L3,18 7,22.2 V19 H19 V13 H17 V17 Z</Geometry>
        <Geometry x:Key="IconChevronLeftGeo">M14.5,5 L8,12 14.5,19 16,17.5 11,12 16,6.5 Z</Geometry>
        <Geometry x:Key="IconChevronRightGeo">M9.5,5 L16,12 9.5,19 8,17.5 13,12 8,6.5 Z</Geometry>
        <Geometry x:Key="IconHomeGeo">M10,20 V14 H14 V20 H19 V12 H22 L12,3 2,12 H5 V20 Z</Geometry>
        <Geometry x:Key="IconTracksGeo">M4,6 H20 V8 H4 Z M4,11 H20 V13 H4 Z M4,16 H14 V18 H4 Z</Geometry>
        <Geometry x:Key="IconAlbumsGeo">M12,2 A10,10 0 1 0 12,22 A10,10 0 1 0 12,2 Z M12,8 A4,4 0 1 0 12,16 A4,4 0 1 0 12,8 Z</Geometry>
        <Geometry x:Key="IconArtistsGeo">M12,12 A4,4 0 1 0 12,4 A4,4 0 1 0 12,12 Z M4,20 C4,16.7 7.6,14 12,14 C16.4,14 20,16.7 20,20</Geometry>
        <Geometry x:Key="IconGenresGeo">M17.6,11.5 L12.7,16.4 C12.3,16.8 11.7,16.8 11.3,16.4 L7.6,12.7 C7.2,12.3 7.2,11.7 7.6,11.3 L12.5,6.4 C12.7,6.2 13,6.1 13.3,6.1 L18,6.5 C18.6,6.6 19,7.1 18.9,7.7 L18.5,12.4 C18.5,12.7 18.4,13 18.2,13.2 Z M14.5,9 A1.2,1.2 0 1 0 14.5,6.6 A1.2,1.2 0 1 0 14.5,9 Z</Geometry>
        <Geometry x:Key="IconInboxGeo">M3,6 H21 V18 H3 Z M3,6 L12,13 21,6</Geometry>
        <Geometry x:Key="IconQueueGeo">M4,6 H16 V8 H4 Z M4,11 H16 V13 H4 Z M4,16 H12 V18 H4 Z M17,15 L21,18 17,21 Z</Geometry>
        <Style x:Key="HubNavIcon" TargetType="Path">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Fill" Value="{DynamicResource HubTextMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12,10,12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="4,0,4,14">
            <Grid Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="Local Music Hub" FontSize="20" FontWeight="Bold"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               Foreground="{DynamicResource HubTextPrimaryBrush}"/>
                    <TextBlock Text="Your home music library — local files, full control"
                               Style="{DynamicResource HubHintText}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Scan library" Style="{DynamicResource HubPrimaryButton}" Click="ScanLibrary_OnClick"/>
                    <Button Content="Scan folders…" Style="{DynamicResource HubToolbarButton}" Click="ScanFolders_OnClick"/>
                    <Button Content="Clean dead files" Style="{DynamicResource HubToolbarButton}" Click="CleanDead_OnClick"/>
                    <Button Content="Settings" Style="{DynamicResource HubToolbarButton}" Click="Settings_OnClick" Margin="0"/>
                </StackPanel>
            </Grid>
            <Border x:Name="UpdateCard" Style="{DynamicResource HubCardBorder}" Padding="12" Margin="0,10,0,0" Visibility="Collapsed">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Update available" FontSize="11" Foreground="{DynamicResource HubAccentBrush}"/>
                        <TextBlock x:Name="UpdateTitle" Style="{DynamicResource HubSectionTitle}" Margin="0,2,0,4"/>
                        <TextBlock x:Name="UpdateBody" Style="{DynamicResource HubBodyText}" Margin="0,0,0,8"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Content="Later" Padding="10,5" Margin="0,0,8,0"
                                Style="{DynamicResource HubToolbarButton}" Click="UpdateLater_OnClick"/>
                        <Button Content="Open download" Padding="12,5"
                                Style="{DynamicResource HubPrimaryButton}" Click="UpdateDownload_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" x:Name="MainContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="240" MinWidth="0"/>
                <ColumnDefinition x:Name="LeftSplitterColumn" Width="6"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition x:Name="RightSplitterColumn" Width="6"/>
                <ColumnDefinition x:Name="RightPanelColumn" Width="300" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="LeftSidebarBorder" Grid.Column="0" Style="{DynamicResource HubCardBorder}" Padding="14">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="Library" Style="{DynamicResource HubSectionTitle}" VerticalAlignment="Center"/>
                        <Button x:Name="HideLeftSidebarButton" Content="‹" HorizontalAlignment="Right"
                                Style="{DynamicResource HubPanelChromeButton}"
                                ToolTip="Hide library panel" Click="HideLeftSidebar_OnClick"/>
                    </Grid>
                    <Border x:Name="DownloaderSidebarCard" DockPanel.Dock="Bottom" Margin="0,12,0,0" Padding="10"
                            Background="{DynamicResource HubMetricBgBrush}" CornerRadius="8">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="YouTube Downloader" Style="{DynamicResource HubSectionTitle}" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="DownloaderCollapseButton" Content="▾" Width="26" Height="26"
                                        HorizontalAlignment="Right" Padding="0"
                                        Style="{DynamicResource HubToolbarButton}"
                                        Click="DownloaderCollapse_OnClick"
                                        ToolTip="Collapse panel"/>
                            </Grid>
                            <StackPanel x:Name="DownloaderSidebarContent">
                                <TextBox x:Name="DownloaderUrlBox" Style="{DynamicResource HubTextBox}" Margin="0,4,0,6"
                                         Height="30" ToolTip="Paste a YouTube music URL"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button x:Name="DownloaderDownloadButton" Content="Download"
                                            Style="{DynamicResource HubPrimaryButton}" Padding="10,4"
                                            Click="DownloaderDownload_OnClick" Margin="0,0,6,0"/>
                                    <Button x:Name="DownloaderPasteButton" Content="Paste &amp; download"
                                            Style="{DynamicResource HubToolbarButton}" Padding="8,4"
                                            Click="DownloaderPasteDownload_OnClick"/>
                                </StackPanel>
                                <TextBlock x:Name="DownloaderStatusText" Style="{DynamicResource HubHintText}"
                                           Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="LibraryStatsText" DockPanel.Dock="Bottom" Style="{DynamicResource HubHintText}"
                               Margin="0,10,0,0" TextWrapping="Wrap"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ListBox x:Name="BrowseList" SelectionChanged="BrowseList_OnSelectionChanged">
                                <ListBoxItem Tag="home" IsSelected="True">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource HubNavIcon}" Data="{StaticResource IconHomeGeo}"/>
                                        <TextBlock Text="Home" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="tracks">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource HubNavIcon}" Data="{StaticResource IconTracksGeo}"/>
                                        <TextBlock Text="All tracks" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="albums">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource HubNavIcon}" Data="{StaticResource IconAlbumsGeo}"/>
                                        <TextBlock Text="Albums" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="artists">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource HubNavIcon}" Data="{StaticResource IconArtistsGeo}"/>
                                        <TextBlock Text="Artists" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="genres">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource HubNavIcon}" Data="{StaticResource IconGenresGeo}"/>
                                        <TextBlock Text="Genres" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="inbox">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource HubNavIcon}" Data="{StaticResource IconInboxGeo}"/>
                                        <TextBlock Text="Inbox" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="queue">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource HubNavIcon}" Data="{StaticResource IconQueueGeo}"/>
                                        <TextBlock Text="Queue" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ListBoxItem>
                            </ListBox>
                            <Button Content="Library tools…" Style="{DynamicResource HubToolbarButton}"
                                    Margin="0,10,0,0" HorizontalAlignment="Stretch"
                                    Click="LibraryTools_OnClick"
                                    ToolTip="Stats, duplicates, organize, ReplayGain, and more"/>

                            <Grid Margin="0,16,0,6">
                                <TextBlock Text="Playlists" Style="{DynamicResource HubSectionTitle}" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="📁" Width="28" Height="28"
                                            Style="{DynamicResource HubToolbarButton}" Margin="0,0,4,0" Padding="0"
                                            Click="NewPlaylistFolder_OnClick" ToolTip="New playlist folder"/>
                                    <Button Content="⚡" Width="28" Height="28"
                                            Style="{DynamicResource HubToolbarButton}" Margin="0,0,4,0" Padding="0"
                                            Click="NewSmartPlaylist_OnClick" ToolTip="New smart playlist…"/>
                                    <Button Content="+" Width="28" Height="28"
                                            Style="{DynamicResource HubToolbarButton}" Margin="0" Padding="0"
                                            Click="NewPlaylist_OnClick" ToolTip="New playlist"/>
                                </StackPanel>
                            </Grid>
                            <TreeView x:Name="PlaylistNavTree"
                                      SelectedItemChanged="PlaylistNavTree_OnSelectedItemChanged"
                                      MouseDoubleClick="PlaylistNavTree_OnMouseDoubleClick">
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate DataType="{x:Type models:PlaylistTreeNode}"
                                                              ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📁" Margin="0,0,8,0" VerticalAlignment="Center"
                                                       Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}"/>
                                            <Border Width="32" Height="32" CornerRadius="4" Margin="0,0,10,0"
                                                    Background="{DynamicResource HubSurfaceRaisedBrush}"
                                                    Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                                <Image Source="{Binding CoverArt, Converter={StaticResource CoverArtConverter}, ConverterParameter=32}"
                                                       Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Text="{Binding NavLabel}" FontWeight="SemiBold" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource HubTextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding TrackCount, StringFormat={} ({0})}" Style="{DynamicResource HubHintText}"
                                                       Margin="6,0,0,0" VerticalAlignment="Center"
                                                       Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.Resources>
                                <TreeView.ContextMenu>
                                    <ContextMenu Opened="PlaylistNavContextMenu_OnOpened">
                                        <MenuItem x:Name="NewSubfolderMenuItem" Header="New subfolder…" Click="NewPlaylistSubfolder_OnClick"/>
                                        <MenuItem x:Name="RenameFolderMenuItem" Header="Rename folder…" Click="RenamePlaylistFolder_OnClick"/>
                                        <MenuItem x:Name="DeleteFolderMenuItem" Header="Delete folder…" Click="DeletePlaylistFolder_OnClick"/>
                                        <Separator x:Name="FolderPlaylistSeparator"/>
                                        <MenuItem x:Name="MovePlaylistMenuItem" Header="Move to folder…" Click="MovePlaylistToFolder_OnClick"/>
                                        <MenuItem x:Name="EditSmartPlaylistMenuItem" Header="Edit rules…" Click="EditSmartPlaylist_OnClick"/>
                                        <MenuItem Header="Export M3U…" Click="ExportPlaylistM3u_OnClick"/>
                                        <MenuItem Header="Import M3U…" Click="ImportPlaylistM3u_OnClick"/>
                                        <MenuItem Header="Rename…" Click="RenamePlaylist_OnClick"/>
                                        <MenuItem Header="Delete…" Click="DeletePlaylist_OnClick"/>
                                    </ContextMenu>
                                </TreeView.ContextMenu>
                            </TreeView>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter x:Name="LeftPanelSplitter" Grid.Column="1" Style="{DynamicResource HubPanelSplitter}"
                          DragCompleted="PanelSplitter_OnDragCompleted"/>

            <Grid Grid.Column="2">
                <Button x:Name="ShowLeftSidebarButton" Content="›" Width="22" Height="48"
                        HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,0,0"
                        Style="{DynamicResource HubPanelChromeButton}"
                        ToolTip="Show library panel" Click="ShowLeftSidebar_OnClick"
                        Visibility="Collapsed" Panel.ZIndex="2"/>
                <Button x:Name="ShowRightSidebarButton" Content="‹" Width="22" Height="48"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{DynamicResource HubPanelChromeButton}"
                        ToolTip="Show queue panel" Click="ShowRightSidebar_OnClick"
                        Visibility="Collapsed" Panel.ZIndex="2"/>
                <Border Style="{DynamicResource HubCardBorder}" Padding="16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock x:Name="ViewTitleText" Text="All tracks" Style="{DynamicResource HubSectionTitle}"
                                   TextTrimming="CharacterEllipsis" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <WrapPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button x:Name="PlaySelectionButton" Content="Play" Style="{DynamicResource HubToolbarButton}"
                                    Click="PlaySelection_OnClick" Margin="0,0,6,4"/>
                            <Button x:Name="OpenSelectionButton" Content="Open" Style="{DynamicResource HubToolbarButton}"
                                    Click="OpenSelection_OnClick" ToolTip="Open album, artist, or genre tracks" Margin="0,0,6,4"/>
                            <Button x:Name="AddQueueButton" Content="Add to queue" Style="{DynamicResource HubToolbarButton}"
                                    Click="AddSelectionToQueue_OnClick" Margin="0,0,6,4"/>
                            <Button x:Name="PlayNextButton" Content="Play next" Style="{DynamicResource HubToolbarButton}"
                                    Click="PlayNext_OnClick" ToolTip="Insert after the current track" Margin="0,0,6,4"/>
                            <Button x:Name="EditAlbumButton" Content="Edit album" Style="{DynamicResource HubToolbarButton}"
                                    Click="EditAlbum_OnClick"
                                    ToolTip="Edit album name, artist, and cover art" Margin="0,0,6,4"/>
                            <TextBox x:Name="SearchBox" Width="160" Style="{DynamicResource HubTextBox}" Margin="0,0,0,4"
                                     TextChanged="SearchBox_OnTextChanged" ToolTip="Search title, artist, album, genre"/>
                        </WrapPanel>
                        <WrapPanel x:Name="QuickFilterPanel" Orientation="Horizontal" Margin="0,4,0,0" Visibility="Collapsed">
                            <TextBlock Text="Filters" Style="{DynamicResource HubHintText}" VerticalAlignment="Center" Margin="0,0,8,4"/>
                            <Button x:Name="FilterNeverPlayedButton" Content="Never played" Tag="never_played"
                                    Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,4" Click="QuickFilter_OnClick"/>
                            <Button x:Name="FilterUnratedButton" Content="Unrated" Tag="unrated"
                                    Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,4" Click="QuickFilter_OnClick"/>
                            <Button x:Name="FilterHighRatedButton" Content="★★★★+" Tag="rated4"
                                    Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,4" Click="QuickFilter_OnClick"/>
                            <Button x:Name="FilterFlacButton" Content="FLAC" Tag="flac"
                                    Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,4" Click="QuickFilter_OnClick"/>
                            <Button x:Name="FilterRecentButton" Content="Added 30d" Tag="recent"
                                    Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,4" Click="QuickFilter_OnClick"/>
                            <Button x:Name="FilterClearButton" Content="Clear" Style="{DynamicResource HubToolbarButton}"
                                    Margin="0,0,0,4" Click="QuickFilterClear_OnClick" ToolTip="Clear all quick filters"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Spotify / iTunes-style album header with clear back navigation -->
                    <Border x:Name="AlbumDetailHeader" DockPanel.Dock="Top" Visibility="Collapsed"
                            Margin="0,0,0,14" Padding="14" Background="{DynamicResource HubMetricBgBrush}"
                            CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="148" Height="148" CornerRadius="10"
                                    Background="{DynamicResource HubCardBrush}" ClipToBounds="True">
                                <Grid>
                                    <TextBlock Text="♪" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource HubTextMutedBrush}"/>
                                    <Image x:Name="AlbumDetailCover" Stretch="Uniform"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                <Button x:Name="BackToAlbumsButton" Content="← All albums"
                                        HorizontalAlignment="Left" Margin="0,0,0,10"
                                        Style="{DynamicResource HubToolbarButton}"
                                        Click="BackToAlbums_OnClick"
                                        ToolTip="Back to album grid"/>
                                <TextBlock x:Name="AlbumDetailKindLabel" Text="ALBUM" Style="{DynamicResource HubHintText}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBlock x:Name="AlbumDetailTitle" Text="Album" FontSize="26" FontWeight="SemiBold"
                                           Foreground="{DynamicResource HubTextPrimaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="AlbumDetailArtist" Style="{DynamicResource HubHintText}"
                                           FontSize="14" Margin="0,4,0,4"/>
                                <TextBlock x:Name="AlbumDetailMeta" Style="{DynamicResource HubHintText}" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="AlbumPlayPauseButton" Width="44" Height="36" Margin="0,0,8,0"
                                            Style="{DynamicResource HubPrimaryButton}"
                                            Click="AlbumPlayPause_OnClick" Padding="0"
                                            ToolTip="Play album">
                                        <Grid Width="16" Height="16">
                                            <Path x:Name="AlbumPlayPausePlayIcon" Width="16" Height="16" Stretch="Uniform"
                                                  Data="{StaticResource IconPlayGeo}" Fill="White" Margin="1,0,0,0"/>
                                            <Path x:Name="AlbumPlayPausePauseIcon" Width="16" Height="16" Stretch="Uniform"
                                                  Data="{StaticResource IconPauseGeo}" Fill="White"
                                                  Visibility="Collapsed"/>
                                        </Grid>
                                    </Button>
                                    <Button Content="Add to queue" Style="{DynamicResource HubToolbarButton}"
                                            Click="AddSelectionToQueue_OnClick"/>
                                    <Button Content="Download lyrics" Style="{DynamicResource HubToolbarButton}"
                                            Click="DownloadAlbumLyrics_OnClick"
                                            ToolTip="Download lyrics for every track on this album (LRCLIB)"/>
                                    <Button Content="Edit album" Style="{DynamicResource HubToolbarButton}"
                                            Click="EditAlbum_OnClick"
                                            ToolTip="Edit album name, artist, and cover art"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid>
                        <ListBox x:Name="TrackList"
                                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 SelectionMode="Extended"
                                 MouseDoubleClick="TrackList_OnMouseDoubleClick"
                                 SelectionChanged="TrackList_OnSelectionChanged"
                                 ItemTemplate="{StaticResource TrackListItemTemplate}"
                                 ContextMenu="{StaticResource LibraryContextMenu}"/>

                        <TextBlock x:Name="EmptyHintText" Style="{DynamicResource HubHintText}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="24"
                                   Visibility="Collapsed"/>

                        <ScrollViewer x:Name="AlbumGridScroller" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseLeftButtonDown="AlbumGrid_OnPreviewMouseLeftButtonDown">
                            <ItemsControl x:Name="AlbumGrid" ItemTemplate="{StaticResource AlbumGridItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>

                        <ScrollViewer x:Name="HomeScroller" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseLeftButtonDown="AlbumGrid_OnPreviewMouseLeftButtonDown">
                            <StackPanel Margin="4,0,4,16">
                                <TextBlock Text="Jump back in" Style="{DynamicResource HubSectionTitle}" Margin="4,0,0,8"/>
                                <TextBlock x:Name="JumpBackInEmpty" Style="{DynamicResource HubHintText}" Margin="4,0,0,12"
                                           Text="Play some music — albums you listen to will show up here."
                                           Visibility="Collapsed"/>
                                <Grid x:Name="JumpBackInCarousel" Margin="0,0,0,20"
                                      MouseEnter="Carousel_OnMouseEnter" MouseLeave="Carousel_OnMouseLeave"
                                      PreviewMouseWheel="Carousel_ForwardWheelVertical_OnPreviewMouseWheel">
                                    <ScrollViewer x:Name="JumpBackInScroller"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  ScrollChanged="Carousel_OnScrollChanged"
                                                  PreviewMouseWheel="Carousel_ForwardWheelVertical_OnPreviewMouseWheel">
                                        <ItemsControl x:Name="JumpBackInGrid" ItemTemplate="{StaticResource AlbumGridItemTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <!-- Overlay band aligned to album art (margin 8 + padding 4 = 12px from card top) -->
                                    <Grid VerticalAlignment="Top" Height="152" Margin="0,12,0,0">
                                        <Button x:Name="JumpBackInLeftButton" Style="{DynamicResource HubCarouselNavButton}"
                                                HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,0,0"
                                                Tag="JumpBackInScroller" Click="CarouselPrev_OnClick"
                                                ToolTip="Scroll left" Visibility="Collapsed">
                                            <Path Width="12" Height="12" Stretch="Uniform"
                                                  Fill="{DynamicResource HubTextPrimaryBrush}"
                                                  Data="{StaticResource IconChevronLeftGeo}"/>
                                        </Button>
                                        <Button x:Name="JumpBackInRightButton" Style="{DynamicResource HubCarouselNavButton}"
                                                HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
                                                Tag="JumpBackInScroller" Click="CarouselNext_OnClick"
                                                ToolTip="Scroll right" Visibility="Collapsed">
                                            <Path Width="12" Height="12" Stretch="Uniform"
                                                  Fill="{DynamicResource HubTextPrimaryBrush}"
                                                  Data="{StaticResource IconChevronRightGeo}"/>
                                        </Button>
                                    </Grid>
                                </Grid>

                                <TextBlock Text="Recently added" Style="{DynamicResource HubSectionTitle}" Margin="4,8,0,8"/>
                                <TextBlock x:Name="RecentlyAddedEmpty" Style="{DynamicResource HubHintText}" Margin="4,0,0,12"
                                           Text="New albums appear here after you import or scan."
                                           Visibility="Collapsed"/>
                                <Grid x:Name="RecentlyAddedCarousel"
                                      MouseEnter="Carousel_OnMouseEnter" MouseLeave="Carousel_OnMouseLeave"
                                      PreviewMouseWheel="Carousel_ForwardWheelVertical_OnPreviewMouseWheel">
                                    <ScrollViewer x:Name="RecentlyAddedScroller"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  ScrollChanged="Carousel_OnScrollChanged"
                                                  PreviewMouseWheel="Carousel_ForwardWheelVertical_OnPreviewMouseWheel">
                                        <ItemsControl x:Name="RecentlyAddedGrid" ItemTemplate="{StaticResource AlbumGridItemTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Grid VerticalAlignment="Top" Height="152" Margin="0,12,0,0">
                                        <Button x:Name="RecentlyAddedLeftButton" Style="{DynamicResource HubCarouselNavButton}"
                                                HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,0,0"
                                                Tag="RecentlyAddedScroller" Click="CarouselPrev_OnClick"
                                                ToolTip="Scroll left" Visibility="Collapsed">
                                            <Path Width="12" Height="12" Stretch="Uniform"
                                                  Fill="{DynamicResource HubTextPrimaryBrush}"
                                                  Data="{StaticResource IconChevronLeftGeo}"/>
                                        </Button>
                                        <Button x:Name="RecentlyAddedRightButton" Style="{DynamicResource HubCarouselNavButton}"
                                                HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
                                                Tag="RecentlyAddedScroller" Click="CarouselNext_OnClick"
                                                ToolTip="Scroll right" Visibility="Collapsed">
                                            <Path Width="12" Height="12" Stretch="Uniform"
                                                  Fill="{DynamicResource HubTextPrimaryBrush}"
                                                  Data="{StaticResource IconChevronRightGeo}"/>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>
            </Border>
            </Grid>

            <GridSplitter x:Name="RightPanelSplitter" Grid.Column="3" Style="{DynamicResource HubPanelSplitter}"
                          DragCompleted="PanelSplitter_OnDragCompleted"/>

            <Border x:Name="RightSidebarBorder" Grid.Column="4" Style="{DynamicResource HubCardBorder}" Padding="14">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ToggleButton x:Name="RightPanelQueueButton" Content="Queue" IsChecked="True"
                                          Style="{DynamicResource HubToolbarToggleButton}"
                                          Click="RightPanelQueue_OnClick"/>
                            <ToggleButton x:Name="RightPanelArtistButton" Content="Artist"
                                          Style="{DynamicResource HubToolbarToggleButton}"
                                          Click="RightPanelArtist_OnClick"/>
                        </StackPanel>
                        <Button x:Name="HideRightSidebarButton" Content="›" HorizontalAlignment="Right"
                                Style="{DynamicResource HubPanelChromeButton}"
                                ToolTip="Hide queue panel" Click="HideRightSidebar_OnClick"/>
                    </Grid>
                    <DockPanel x:Name="QueuePanel">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="48"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Play queue" Style="{DynamicResource HubSectionTitle}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="↑" Width="28" Style="{DynamicResource HubToolbarButton}" Margin="0,0,4,0"
                                    Padding="0" Click="QueueMoveUp_OnClick" ToolTip="Move up"/>
                            <Button Content="↓" Width="28" Style="{DynamicResource HubToolbarButton}" Margin="0,0,4,0"
                                    Padding="0" Click="QueueMoveDown_OnClick" ToolTip="Move down"/>
                            <Button Content="Remove" Style="{DynamicResource HubToolbarButton}" Margin="0,0,4,0"
                                    Click="QueueRemove_OnClick"/>
                            <Button Content="Clear" Style="{DynamicResource HubToolbarButton}" Margin="0"
                                    Click="QueueClear_OnClick"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="QueueStatsText" DockPanel.Dock="Bottom" Style="{DynamicResource HubHintText}" Margin="0,8,0,0"/>
                    <ListBox x:Name="QueueList"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ItemTemplate="{StaticResource TrackListItemTemplate}"
                             MouseDoubleClick="QueueList_OnMouseDoubleClick"/>
                    </DockPanel>
                    <ScrollViewer x:Name="ArtistPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Width="120" Height="120" CornerRadius="60" Margin="0,0,0,12"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource HubSurfaceRaisedBrush}">
                                <Image x:Name="ArtistPanelImage" Stretch="UniformToFill"/>
                            </Border>
                            <TextBlock x:Name="ArtistPanelName" Style="{DynamicResource HubSectionTitle}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="ArtistPanelStats" Style="{DynamicResource HubHintText}" Margin="0,6,0,10" TextWrapping="Wrap"/>
                            <TextBlock x:Name="ArtistPanelBio" TextWrapping="Wrap"/>
                            <TextBlock x:Name="ArtistPanelSource" Style="{DynamicResource HubHintText}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{DynamicResource HubCardBorder}" Padding="14,12" Margin="0,10,0,0"
                Background="{DynamicResource HubNowPlayingBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="220"/>
                    <ColumnDefinition Width="*" MinWidth="280"/>
                    <ColumnDefinition Width="Auto" MinWidth="220"/>
                </Grid.ColumnDefinitions>

                <!-- Left: track identity -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="56" Height="56" CornerRadius="8" Background="{DynamicResource HubMetricBgBrush}" ClipToBounds="True">
                        <Grid>
                            <TextBlock Text="♪" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource HubTextMutedBrush}"/>
                            <Image x:Name="NowPlayingCover" Stretch="Uniform"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center" MaxWidth="200">
                        <TextBlock x:Name="NowPlayingTitle" Text="Nothing playing" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource HubTextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="NowPlayingArtist" Style="{DynamicResource HubHintText}" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="NowPlayingStats" Style="{DynamicResource HubHintText}" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis" FontSize="11"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <local:StarRatingControl x:Name="NowPlayingRating"
                                                     RatingChanged="NowPlayingRating_OnRatingChanged"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Center: transport + seek -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <Button x:Name="ShuffleButton" Width="36" Height="36" Style="{DynamicResource HubToolbarButton}"
                                Background="Transparent" Margin="0,0,6,0" Padding="0"
                                ToolTip="Shuffle" Click="Shuffle_OnClick">
                            <Path x:Name="ShuffleIcon" Style="{StaticResource HubTransportIcon}"
                                  Data="{StaticResource IconShuffleGeo}"/>
                        </Button>
                        <Button Width="40" Height="36" Style="{DynamicResource HubToolbarButton}"
                                Background="Transparent" Margin="0,0,6,0" Padding="0"
                                ToolTip="Previous" Click="Previous_OnClick">
                            <Path Style="{StaticResource HubTransportIcon}" Data="{StaticResource IconPrevGeo}"/>
                        </Button>
                        <Button x:Name="PlayPauseButton" Width="44" Height="44" Style="{DynamicResource HubPrimaryButton}"
                                Click="PlayPause_OnClick" Margin="0,0,6,0" Padding="0" ToolTip="Play / Pause">
                            <Grid Width="18" Height="18">
                                <Path x:Name="PlayPausePlayIcon" Width="16" Height="16" Stretch="Uniform"
                                      Data="{StaticResource IconPlayGeo}"
                                      Fill="White"
                                      Margin="1,0,0,0"/>
                                <Path x:Name="PlayPausePauseIcon" Width="16" Height="16" Stretch="Uniform"
                                      Data="{StaticResource IconPauseGeo}"
                                      Fill="White"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                        <Button Width="40" Height="36" Style="{DynamicResource HubToolbarButton}"
                                Background="Transparent" Margin="0,0,6,0" Padding="0"
                                ToolTip="Next" Click="Next_OnClick">
                            <Path Style="{StaticResource HubTransportIcon}" Data="{StaticResource IconNextGeo}"/>
                        </Button>
                        <Button x:Name="RepeatButton" Width="36" Height="36" Style="{DynamicResource HubToolbarButton}"
                                Background="Transparent" Margin="0" Padding="0"
                                ToolTip="Repeat" Click="Repeat_OnClick">
                            <Grid Width="20" Height="20">
                                <Path x:Name="RepeatIcon" Style="{StaticResource HubTransportIcon}" Width="18" Height="18"
                                      Data="{StaticResource IconRepeatGeo}"/>
                                <Border x:Name="RepeatOneBadge" Width="10" Height="10" CornerRadius="5"
                                        Background="{DynamicResource HubAccentBrush}"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Margin="0,0,-1,-1" Visibility="Collapsed">
                                    <TextBlock Text="1" FontSize="7" FontWeight="Bold"
                                               Foreground="{DynamicResource HubPrimaryForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ElapsedText" Text="0:00" Style="{DynamicResource HubHintText}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                        <Slider x:Name="PositionSlider" Grid.Column="1" Minimum="0" Maximum="1" Value="0"
                                VerticalAlignment="Center"
                                IsMoveToPointEnabled="True"
                                PreviewMouseDown="PositionSlider_OnPreviewMouseDown"
                                LostMouseCapture="PositionSlider_OnLostMouseCapture"
                                ValueChanged="PositionSlider_OnValueChanged"/>
                        <TextBlock x:Name="RemainingText" Grid.Column="2" Text="0:00" Style="{DynamicResource HubHintText}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>

                <!-- Right: volume + utilities -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <ComboBox x:Name="SpeedCombo" Width="52" Margin="0,0,8,0"
                              Style="{DynamicResource HubComboBox}"
                              ToolTip="Playback speed (pitch shifts with tempo)"
                              SelectionChanged="SpeedCombo_OnSelectionChanged">
                        <ComboBoxItem Content="0.5×" Tag="0.5"/>
                        <ComboBoxItem Content="0.75×" Tag="0.75"/>
                        <ComboBoxItem Content="1×" Tag="1"/>
                        <ComboBoxItem Content="1.25×" Tag="1.25"/>
                        <ComboBoxItem Content="1.5×" Tag="1.5"/>
                        <ComboBoxItem Content="2×" Tag="2"/>
                    </ComboBox>
                    <Button x:Name="MuteButton" Content="🔊" Width="36" Height="36" Style="{DynamicResource HubToolbarButton}" Margin="0,0,4,0"
                            ToolTip="Mute / unmute" Click="Mute_OnClick" Padding="0"/>
                    <Slider x:Name="VolumeSlider" Width="100" Minimum="0" Maximum="1" Value="0.85"
                            Style="{DynamicResource HubVolumeSlider}"
                            VerticalAlignment="Center" Margin="0,0,10,0"
                            IsMoveToPointEnabled="True"
                            ValueChanged="VolumeSlider_OnValueChanged"
                            ToolTip="Volume"/>
                    <Button x:Name="SleepTimerButton" Content="Sleep" Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,0"
                            ToolTip="Sleep timer" Click="SleepTimer_OnClick"/>
                    <Button Content="Mini" Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,0"
                            ToolTip="Open mini player" Click="MiniPlayer_OnClick"/>
                    <Button Content="Lyrics" Style="{DynamicResource HubToolbarButton}" Margin="0"
                            ToolTip="Show lyrics for the current track" Click="Lyrics_OnClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
