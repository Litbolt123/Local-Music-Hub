<Window x:Class="LocalMusicHub.TextPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Name"
        Height="200" Width="420"
        MinHeight="180" MinWidth="360"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="PromptText" Style="{DynamicResource HubSectionTitle}" Margin="0,0,0,10"/>
        <TextBox x:Name="InputBox" Grid.Row="1" Style="{DynamicResource HubTextBox}" Height="32"
                 VerticalContentAlignment="Center"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{DynamicResource HubToolbarButton}" IsCancel="True" Padding="14,8"/>
            <Button Content="OK" Style="{DynamicResource HubPrimaryButton}" IsDefault="True" Padding="16,8" Click="Ok_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
