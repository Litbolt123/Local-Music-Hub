<Window x:Class="LocalMusicHub.LibraryToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library tools"
        Height="420" Width="520"
        MinHeight="360" MinWidth="440"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Library tools" Style="{DynamicResource HubSectionTitle}" FontSize="18"/>
            <TextBlock x:Name="SummaryText" Style="{DynamicResource HubHintText}" Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="2" Rows="3" Margin="0,0,0,12">
            <Button Style="{DynamicResource HubToolbarButton}" Margin="0,0,8,8" Padding="14,16"
                    HorizontalContentAlignment="Left" Click="Stats_OnClick">
                <StackPanel>
                    <TextBlock Text="Library stats" FontWeight="SemiBold"/>
                    <TextBlock Text="Counts, formats, ratings" Style="{DynamicResource HubHintText}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{DynamicResource HubToolbarButton}" Margin="0,0,0,8" Padding="14,16"
                    HorizontalContentAlignment="Left" Click="Duplicates_OnClick">
                <StackPanel>
                    <TextBlock Text="Find duplicates" FontWeight="SemiBold"/>
                    <TextBlock Text="Same song, multiple files" Style="{DynamicResource HubHintText}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{DynamicResource HubToolbarButton}" Margin="0,0,8,8" Padding="14,16"
                    HorizontalContentAlignment="Left" Click="Organize_OnClick">
                <StackPanel>
                    <TextBlock Text="Organize files" FontWeight="SemiBold"/>
                    <TextBlock Text="Rename / move by template" Style="{DynamicResource HubHintText}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{DynamicResource HubToolbarButton}" Margin="0,0,0,8" Padding="14,16"
                    HorizontalContentAlignment="Left" Click="ReplayGain_OnClick">
                <StackPanel>
                    <TextBlock Text="Scan ReplayGain" FontWeight="SemiBold"/>
                    <TextBlock Text="Analyze volume levels" Style="{DynamicResource HubHintText}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{DynamicResource HubToolbarButton}" Margin="0,0,8,8" Padding="14,16"
                    HorizontalContentAlignment="Left" Click="CleanDead_OnClick">
                <StackPanel>
                    <TextBlock Text="Clean dead files" FontWeight="SemiBold"/>
                    <TextBlock Text="Remove missing paths" Style="{DynamicResource HubHintText}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{DynamicResource HubToolbarButton}" Margin="0,0,0,8" Padding="14,16"
                    HorizontalContentAlignment="Left" Click="ScanLibrary_OnClick">
                <StackPanel>
                    <TextBlock Text="Scan library" FontWeight="SemiBold"/>
                    <TextBlock Text="Rescan monitored folders" Style="{DynamicResource HubHintText}" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
        </UniformGrid>

        <Button Grid.Row="2" Content="Close" Style="{DynamicResource HubPrimaryButton}"
                HorizontalAlignment="Right" Padding="16,8" IsCancel="True"/>
    </Grid>
</Window>
