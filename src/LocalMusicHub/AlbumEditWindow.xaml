<Window x:Class="LocalMusicHub.AlbumEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit album"
        Height="280" Width="460"
        MinHeight="260" MinWidth="400"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Edit album" Style="{DynamicResource HubSectionTitle}" FontSize="18"/>
            <TextBlock x:Name="SubtitleText" Style="{DynamicResource HubHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{DynamicResource HubCardBorder}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Album artist" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,10"/>
                <TextBox x:Name="AlbumArtistBox" Grid.Column="1" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="Album" Style="{DynamicResource HubSettingLabel}"/>
                <TextBox x:Name="AlbumBox" Grid.Row="1" Grid.Column="1" Style="{DynamicResource HubTextBox}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Style="{DynamicResource HubToolbarButton}" IsCancel="True" Padding="14,8"/>
            <Button Content="Apply to album" Style="{DynamicResource HubPrimaryButton}" IsDefault="True" Padding="16,8" Click="Apply_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
