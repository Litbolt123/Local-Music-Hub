<Window x:Class="LocalMusicHub.AlbumEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit album"
        Height="760" Width="880"
        MinHeight="520" MinWidth="700"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        AllowDrop="True"
        Drop="Window_OnDrop"
        DragOver="Window_OnDragOver">
    <!-- Footer docked so Save/Cancel stay visible at any window height. -->
    <DockPanel Margin="18">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{DynamicResource HubToolbarButton}" IsCancel="True" Padding="14,8"/>
            <Button Content="Save album" Style="{DynamicResource HubPrimaryButton}" IsDefault="True" Padding="16,8"
                    Click="Save_OnClick"/>
        </StackPanel>
        <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom" Style="{DynamicResource HubHintText}" Margin="0,8,0,0"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="140"/>
                <RowDefinition Height="1.15*" MinHeight="120"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Edit album" Style="{DynamicResource HubSectionTitle}" FontSize="18"/>
                <TextBlock x:Name="SubtitleText" Style="{DynamicResource HubHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Metadata (scrolls when the pane is short) -->
                <Border Style="{DynamicResource HubCardBorder}" Padding="14">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Album details" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,10"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="Album artist" Style="{DynamicResource HubHintText}" Margin="0,0,0,4"
                                           ToolTip="Album-level artist tag (used for sorting and album grouping)."/>
                                <TextBox x:Name="AlbumArtistBox" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"
                                         ToolTip="Applied to every track’s album artist on Save."/>
                                <TextBlock Text="Artist (all tracks)" Style="{DynamicResource HubHintText}" Margin="0,0,0,4"
                                           ToolTip="Sets the per-track Artist tag for every song on this album."/>
                                <DockPanel Margin="0,0,0,4">
                                    <Button DockPanel.Dock="Right" Content="Apply ↓" Style="{DynamicResource HubToolbarButton}"
                                            Margin="8,0,0,0" Padding="10,6" VerticalAlignment="Center"
                                            Click="ApplyTrackArtist_OnClick"
                                            ToolTip="Fill the Artist column for every track below"/>
                                    <TextBox x:Name="TrackArtistBox" Style="{DynamicResource HubTextBox}"
                                             ToolTip="Used when “Apply artist to all tracks on Save” is checked."/>
                                </DockPanel>
                                <WrapPanel Margin="0,0,0,10">
                                    <Button Content="Same as album artist" Style="{DynamicResource HubToolbarButton}"
                                            Margin="0,0,8,6" Padding="10,4"
                                            Click="CopyAlbumArtistToTrackArtist_OnClick"
                                            ToolTip="Copy Album artist into Artist (all tracks)"/>
                        <CheckBox x:Name="ApplyTrackArtistOnSaveBox" Style="{DynamicResource HubSimpleCheckBox}"
                                  Content="Apply artist to all tracks on Save" IsChecked="False"
                                  VerticalAlignment="Center" Margin="0,0,0,6"
                                  ToolTip="When checked and Artist (all tracks) is filled, every track gets that Artist tag on Save."/>
                                </WrapPanel>
                                <TextBlock Text="Album" Style="{DynamicResource HubHintText}" Margin="0,0,0,4"/>
                                <TextBox x:Name="AlbumBox" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"/>
                                <TextBlock Text="Year" Style="{DynamicResource HubHintText}" Margin="0,0,0,4"/>
                                <TextBox x:Name="YearBox" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"/>
                                <TextBlock Text="Genre" Style="{DynamicResource HubHintText}" Margin="0,0,0,4"/>
                                <TextBox x:Name="GenreBox" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"/>
                                <TextBlock Text="Date released" Style="{DynamicResource HubHintText}" Margin="0,0,0,4"/>
                                <TextBox x:Name="DateReleasedBox" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"
                                         ToolTip="Year or full date (e.g. 2016 or 2016-02-26). Applied to all tracks."/>
                                <TextBlock Text="Comments" Style="{DynamicResource HubHintText}" Margin="0,0,0,4"/>
                                <TextBox x:Name="CommentsBox" Style="{DynamicResource HubTextBox}" Margin="0,0,0,10"
                                         MinHeight="52" MaxHeight="88" TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         ToolTip="Applied to all tracks on this album."/>
                                <TextBlock x:Name="TrackCountText" Style="{DynamicResource HubHintText}" TextWrapping="Wrap"
                                           Text="Album fields apply to all tracks. Edit individual songs below."/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Cover -->
                <Border Grid.Column="2" Style="{DynamicResource HubCardBorder}" Padding="14">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Cover art" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,10"/>
                        <TextBlock x:Name="CoverStatusText" DockPanel.Dock="Bottom" Style="{DynamicResource HubHintText}"
                                   TextWrapping="Wrap" Margin="0,10,0,0"
                                   Text="Drop an image here, or use the buttons below."/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <Border Width="160" Height="160" HorizontalAlignment="Center"
                                        CornerRadius="8" Background="{DynamicResource HubMetricBgBrush}"
                                        ClipToBounds="True" Margin="0,0,0,12"
                                        AllowDrop="True" Drop="Window_OnDrop" DragOver="Window_OnDragOver"
                                        ToolTip="Drop an image file here">
                                    <Grid>
                                        <TextBlock Text="♪" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource HubTextMutedBrush}"/>
                                        <Image x:Name="PreviewImage" Stretch="Uniform"/>
                                    </Grid>
                                </Border>

                                <WrapPanel Margin="0,0,0,8">
                                    <Button Content="Choose image…" Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,6"
                                            Click="ChooseImage_OnClick"/>
                                    <Button Content="Paste" Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,6"
                                            Click="Paste_OnClick" ToolTip="Paste image from clipboard"/>
                                    <Button Content="Fetch online…" Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,6"
                                            Click="FetchOnline_OnClick"
                                            ToolTip="Look up cover on Apple Music / Deezer"/>
                                    <Button Content="Reset" Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,6"
                                            Click="ResetCover_OnClick" ToolTip="Restore the original cover"/>
                                    <Button Content="Remove" Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,6"
                                            Click="RemoveCover_OnClick" ToolTip="Clear cover art from the album"/>
                                </WrapPanel>

                                <WrapPanel Margin="0,0,0,10">
                                    <Button Content="⟲ 90°" Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,6"
                                            Click="RotateLeft_OnClick"/>
                                    <Button Content="⟳ 90°" Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,6"
                                            Click="RotateRight_OnClick"/>
                                    <Button Content="Center" Style="{DynamicResource HubToolbarButton}" Margin="0,0,6,6"
                                            Click="Center_OnClick"/>
                                </WrapPanel>

                                <TextBlock Text="Horizontal shift" Style="{DynamicResource HubHintText}" Margin="0,0,0,4"/>
                                <Slider x:Name="OffsetXSlider" Minimum="-1" Maximum="1" Value="0"
                                        ValueChanged="Preview_OnChanged"/>
                                <TextBlock Text="Vertical shift" Style="{DynamicResource HubHintText}" Margin="0,8,0,4"/>
                                <Slider x:Name="OffsetYSlider" Minimum="-1" Maximum="1" Value="0"
                                        ValueChanged="Preview_OnChanged"/>
                                <TextBlock Text="Zoom" Style="{DynamicResource HubHintText}" Margin="0,8,0,4"/>
                                <Slider x:Name="ZoomSlider" Minimum="1" Maximum="3" Value="1" TickFrequency="0.05"
                                        ValueChanged="Preview_OnChanged"/>

                                <TextBlock Text="Output size" Style="{DynamicResource HubHintText}" Margin="0,12,0,4"/>
                                <ComboBox x:Name="OutputSizeBox" MinHeight="28" SelectedIndex="1">
                                    <ComboBoxItem Content="600 px" Tag="600"/>
                                    <ComboBoxItem Content="800 px" Tag="800"/>
                                    <ComboBoxItem Content="1000 px" Tag="1000"/>
                                    <ComboBoxItem Content="1200 px" Tag="1200"/>
                                </ComboBox>

                                <TextBlock Text="JPEG quality" Style="{DynamicResource HubHintText}" Margin="0,10,0,4"/>
                                <DockPanel>
                                    <TextBlock x:Name="QualityLabel" DockPanel.Dock="Right" Width="36" Text="90"
                                               Style="{DynamicResource HubHintText}" VerticalAlignment="Center"/>
                                    <Slider x:Name="QualitySlider" Minimum="60" Maximum="100" Value="90"
                                            ValueChanged="Quality_OnChanged"/>
                                </DockPanel>

                                <CheckBox x:Name="UpdateCoverBox" Style="{DynamicResource HubSimpleCheckBox}" Margin="0,14,0,0"
                                          Content="Update cover on save" IsChecked="True"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{DynamicResource HubCardBorder}" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Tracks" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,8"/>
                    <ListView x:Name="TrackList" ItemsSource="{Binding TrackRows}" BorderThickness="0"
                              Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="44">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding TrackNumberText, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{DynamicResource HubTextBox}" Padding="4,2"
                                                     IsEnabled="{Binding IsEditable}" ToolTip="Track number"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Title" Width="220">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{DynamicResource HubTextBox}" Padding="4,2"
                                                     IsEnabled="{Binding IsEditable}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Artist" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Artist, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{DynamicResource HubTextBox}" Padding="4,2"
                                                     IsEnabled="{Binding IsEditable}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Rating" Width="72">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedIndex="{Binding Rating, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding IsEditable}" MinWidth="64" Padding="2,0">
                                                <ComboBoxItem Content="—"/>
                                                <ComboBoxItem Content="★"/>
                                                <ComboBoxItem Content="★★"/>
                                                <ComboBoxItem Content="★★★"/>
                                                <ComboBoxItem Content="★★★★"/>
                                                <ComboBoxItem Content="★★★★★"/>
                                            </ComboBox>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Duration" Width="56" DisplayMemberBinding="{Binding DurationLabel}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
