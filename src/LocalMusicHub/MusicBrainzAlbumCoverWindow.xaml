<Window x:Class="LocalMusicHub.MusicBrainzAlbumCoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MusicBrainz album cover"
        Height="580" Width="720"
        MinHeight="460" MinWidth="600"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,10">
            <TextBlock Text="Fetch album cover" Style="{DynamicResource HubSectionTitle}" FontSize="18"/>
            <TextBlock x:Name="AlbumText" Style="{DynamicResource HubHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Album artist" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,4"/>
                <TextBox x:Name="ArtistBox" Style="{DynamicResource HubTextBox}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <TextBlock Text="Album" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,4"/>
                <TextBox x:Name="AlbumBox" Style="{DynamicResource HubTextBox}"/>
            </StackPanel>
            <Button Grid.Column="2" Content="Search" Style="{DynamicResource HubPrimaryButton}"
                    VerticalAlignment="Bottom" Padding="16,8" Click="Search_OnClick"/>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <Border Style="{DynamicResource HubCardBorder}" Padding="8" Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock x:Name="StatusText" DockPanel.Dock="Top" Style="{DynamicResource HubHintText}" Margin="6,4,6,8"/>
                    <ListBox x:Name="ResultsList" DisplayMemberPath="DisplayLabel"
                             SelectionChanged="ResultsList_OnSelectionChanged"/>
                </DockPanel>
            </Border>
            <Border Grid.Column="1" Style="{DynamicResource HubCardBorder}" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Cover preview" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,8"/>
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <ProgressBar x:Name="CoverProgress" Height="6" Minimum="0" Maximum="1" Value="0"
                                     Visibility="Collapsed"/>
                        <TextBlock x:Name="CoverStatusText" Style="{DynamicResource HubHintText}"
                                   TextWrapping="Wrap" Margin="0,6,0,0" Text="Select a release."/>
                    </StackPanel>
                    <Border Background="{DynamicResource HubMetricBgBrush}" CornerRadius="6">
                        <Image x:Name="CoverPreview" Stretch="Uniform" MaxWidth="150" MaxHeight="150"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Style="{DynamicResource HubToolbarButton}" IsCancel="True" Padding="14,8"/>
            <Button Content="Apply cover to album" Style="{DynamicResource HubPrimaryButton}" Padding="16,8"
                    Click="Apply_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
