<Window x:Class="LocalMusicHub.DuplicatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Duplicate tracks"
        Height="640" Width="920"
        MinHeight="480" MinWidth="760"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Duplicate tracks" Style="{DynamicResource HubSectionTitle}" FontSize="18"/>
            <TextBlock x:Name="SummaryText" Style="{DynamicResource HubHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ListBox x:Name="GroupsList" SelectionChanged="GroupsList_OnSelectionChanged"
                     DisplayMemberPath="Key"/>
            <ListBox x:Name="TracksList" Grid.Column="2" SelectionChanged="TracksList_OnSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding QualityLine}" Style="{DynamicResource HubHintText}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Keep best in group" Style="{DynamicResource HubToolbarButton}" Padding="14,8" Margin="0,0,8,0"
                    Click="KeepBest_OnClick" ToolTip="Keep the highest-quality file; delete the others in this group"/>
            <Button Content="Keep best in all" Style="{DynamicResource HubToolbarButton}" Padding="14,8" Margin="0,0,8,0"
                    Click="KeepBestAll_OnClick" ToolTip="For every group, keep the best file and delete the rest"/>
            <Button Content="Open folder" Style="{DynamicResource HubToolbarButton}" Padding="14,8" Margin="0,0,8,0"
                    Click="OpenFolder_OnClick"/>
            <Button Content="Delete selected" Style="{DynamicResource HubToolbarButton}" Padding="14,8" Margin="0,0,8,0"
                    Click="DeleteSelected_OnClick"/>
            <Button Content="Close" Style="{DynamicResource HubPrimaryButton}" Padding="16,8" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
