<Window x:Class="LocalMusicHub.MusicBrainzTagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MusicBrainz lookup"
        Height="640" Width="760"
        MinHeight="500" MinWidth="640"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,10">
            <TextBlock Text="MusicBrainz lookup" Style="{DynamicResource HubSectionTitle}" FontSize="18"/>
            <TextBlock x:Name="CurrentText" Style="{DynamicResource HubHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Artist" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,4"/>
                <TextBox x:Name="ArtistBox" Style="{DynamicResource HubTextBox}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <TextBlock Text="Title" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleBox" Style="{DynamicResource HubTextBox}"/>
            </StackPanel>
            <Button Grid.Column="2" Content="Search" Style="{DynamicResource HubPrimaryButton}"
                    VerticalAlignment="Bottom" Padding="16,8" Click="Search_OnClick"/>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <Border Style="{DynamicResource HubCardBorder}" Padding="8" Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock x:Name="StatusText" DockPanel.Dock="Top" Style="{DynamicResource HubHintText}" Margin="6,4,6,8"/>
                    <ListBox x:Name="ResultsList" DisplayMemberPath="DisplayLabel"
                             SelectionChanged="ResultsList_OnSelectionChanged"/>
                </DockPanel>
            </Border>
            <Border Grid.Column="1" Style="{DynamicResource HubCardBorder}" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Cover preview" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,8"/>
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <ProgressBar x:Name="CoverProgress" Height="6" Minimum="0" Maximum="1" Value="0"
                                     Visibility="Collapsed"/>
                        <TextBlock x:Name="CoverStatusText" Style="{DynamicResource HubHintText}"
                                   TextWrapping="Wrap" Margin="0,6,0,0" Text="Select a release to preview."/>
                    </StackPanel>
                    <Border Background="{DynamicResource HubMetricBgBrush}" CornerRadius="6">
                        <Image x:Name="CoverPreview" Stretch="Uniform" MaxWidth="140" MaxHeight="140"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock Text="Release (album + cover lookup)" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,4"/>
            <ComboBox x:Name="ReleaseCombo" MinHeight="30" DisplayMemberPath="Label"
                      SelectionChanged="ReleaseCombo_OnSelectionChanged"/>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <CheckBox x:Name="FetchCoverBox" Style="{DynamicResource HubSimpleCheckBox}"
                          Content="Include cover (Apple / Deezer)" IsChecked="True"
                          VerticalAlignment="Center" Checked="FetchCoverBox_OnChanged" Unchecked="FetchCoverBox_OnChanged"/>
                <Button Content="Preview cover" Style="{DynamicResource HubToolbarButton}" Margin="12,0,0,0"
                        Padding="10,4" Click="PreviewCover_OnClick"
                        ToolTip="Fetch cover from Apple Music or Deezer"/>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Style="{DynamicResource HubToolbarButton}" IsCancel="True" Padding="14,8"/>
            <Button Content="Apply selected" Style="{DynamicResource HubPrimaryButton}" Padding="16,8" Click="Apply_OnClick"
                    ToolTip="Applies tags now. If cover is still downloading, waits for that shared download."/>
        </StackPanel>
    </Grid>
</Window>
