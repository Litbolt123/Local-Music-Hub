<Window x:Class="LocalMusicHub.CoverAdjustWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adjust cover art"
        Height="560" Width="480"
        MinHeight="500" MinWidth="420"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Adjust cover art" Style="{DynamicResource HubSectionTitle}" FontSize="18"/>
            <TextBlock x:Name="SubtitleText" Style="{DynamicResource HubHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{DynamicResource HubCardBorder}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Width="240" Height="240" HorizontalAlignment="Center" VerticalAlignment="Center"
                        CornerRadius="8" Background="{DynamicResource HubMetricBgBrush}" ClipToBounds="True">
                    <Grid>
                        <TextBlock Text="♪" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource HubTextMutedBrush}"/>
                        <Image x:Name="PreviewImage" Stretch="Uniform"/>
                    </Grid>
                </Border>
                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <TextBlock Text="Horizontal shift" Style="{DynamicResource HubSettingLabel}" Margin="0,0,0,4"/>
                    <Slider x:Name="OffsetXSlider" Minimum="-1" Maximum="1" Value="0" TickFrequency="0.05"
                            IsSnapToTickEnabled="False" ValueChanged="Offset_OnValueChanged"/>
                    <TextBlock Text="Vertical shift" Style="{DynamicResource HubSettingLabel}" Margin="0,10,0,4"/>
                    <Slider x:Name="OffsetYSlider" Minimum="-1" Maximum="1" Value="0" TickFrequency="0.05"
                            IsSnapToTickEnabled="False" ValueChanged="Offset_OnValueChanged"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Center" Style="{DynamicResource HubToolbarButton}" Click="Center_OnClick"/>
                        <Button Content="Choose image…" Style="{DynamicResource HubToolbarButton}" Click="ChooseImage_OnClick"/>
                        <Button Content="Find cover…" Style="{DynamicResource HubToolbarButton}" Click="MusicBrainz_OnClick"
                                ToolTip="Search Apple Music / Deezer for a cover and load into this preview"/>
                    </StackPanel>
                    <CheckBox x:Name="ApplyAlbumBox" Style="{DynamicResource HubSimpleCheckBox}" Margin="0,12,0,0"
                              Content="Apply to all tracks on this album"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock x:Name="StatusText" Grid.Row="2" Style="{DynamicResource HubHintText}" Margin="0,10,0,0"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Style="{DynamicResource HubToolbarButton}" IsCancel="True" Padding="14,8"/>
            <Button Content="Save" Style="{DynamicResource HubPrimaryButton}" IsDefault="True" Padding="16,8" Click="Save_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
