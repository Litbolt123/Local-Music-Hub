<Window x:Class="LocalMusicHub.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library statistics"
        Height="620" Width="680"
        MinHeight="480" MinWidth="560"
        Background="{DynamicResource HubBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Library statistics" Style="{DynamicResource HubSectionTitle}" FontSize="18" Margin="0,0,0,12"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
            <StackPanel x:Name="ContentPanel" Margin="0,0,12,8"/>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Export CSV…" Style="{DynamicResource HubToolbarButton}" Padding="14,8" Margin="0,0,8,0"
                    Click="ExportCsv_OnClick"/>
            <Button Content="Close" Style="{DynamicResource HubPrimaryButton}" Padding="16,8" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
